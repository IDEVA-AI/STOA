# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# JWT_SECRET: Secret key used to sign and verify JSON Web Tokens for authentication.
# Use a long, random string (e.g. openssl rand -hex 32).
JWT_SECRET="MY_JWT_SECRET"

# BUNNY_API_KEY: API key for Bunny.net Stream video hosting service.
# Found in your Bunny.net dashboard under Stream > API.
BUNNY_API_KEY="MY_BUNNY_API_KEY"

# BUNNY_LIBRARY_ID: The numeric ID of your Bunny.net Stream library.
# Found in your Bunny.net Stream dashboard under Library settings.
BUNNY_LIBRARY_ID="MY_BUNNY_LIBRARY_ID"

# BUNNY_CDN_HOSTNAME: The CDN hostname for serving video content from Bunny.net.
# Example: vz-abc123de-fg4.b-cdn.net
BUNNY_CDN_HOSTNAME="MY_BUNNY_CDN_HOSTNAME"

# DB_PATH: File path for the SQLite database.
# Can be relative to the project root or an absolute path.
DB_PATH="./data/stoa.db"

# PORT: The port the server listens on.
# Defaults to 3000 if not set.
PORT="3000"
